<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".fragments.SelectDoctorFragment">

    <TextView
        android:id="@+id/text_select_doctor_title"
        style="@style/Text.SMD.DisplaySemibold18"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginTop="@dimen/space_24"
        android:text="@string/select_doctor_title"
        android:textColor="@color/base_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_select_doctor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginTop="@dimen/space_16"
        android:layout_marginEnd="@dimen/space_24"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_select_doctor_title"
        tools:itemCount="6"
        tools:listitem="@layout/item_doctor_recommendation" />

    <TextView
        android:id="@+id/text_select_doctor_empty"
        style="@style/Text.SMD.Regular14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_doctor_empty"
        android:textColor="@color/neutral_500"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/recycler_select_doctor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/recycler_select_doctor" />

</androidx.constraintlayout.widget.ConstraintLayout>
