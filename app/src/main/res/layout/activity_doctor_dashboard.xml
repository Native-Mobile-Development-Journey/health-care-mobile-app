<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/doctor_dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".DoctorDashboardActivity">

    <TextView
        android:id="@+id/text_doctor_dashboard_title"
        style="@style/Text.SMD.DisplaySemibold18"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginTop="@dimen/space_32"
        android:layout_marginEnd="@dimen/space_24"
        android:text="@string/doctor_dashboard_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_doctor_dashboard_subtitle"
        style="@style/Text.SMD.Regular14"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginTop="@dimen/space_8"
        android:layout_marginEnd="@dimen/space_24"
        android:text="@string/doctor_dashboard_subtitle"
        android:textColor="@color/neutral_500"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_doctor_dashboard_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
