<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_date_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/space_8"
    android:background="@drawable/bg_date_chip_default"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_16"
    android:paddingTop="@dimen/space_12"
    android:paddingEnd="@dimen/space_16"
    android:paddingBottom="@dimen/space_12">

    <TextView
        android:id="@+id/text_day_label"
        style="@style/Text.SMD.Regular12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/value_unavailable"
        android:textColor="@color/neutral_400" />

    <TextView
        android:id="@+id/text_date_label"
        style="@style/Text.SMD.TitleMedium16"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/value_unavailable"
        android:textColor="@color/neutral_400" />

</LinearLayout>
