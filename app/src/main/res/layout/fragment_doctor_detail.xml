<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".fragments.DoctorDetailFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detail_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/button_confirm_schedule"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/detail_hero_height"
                android:background="@color/primary_500">

                <ImageButton
                    android:id="@+id/button_back"
                    android:layout_width="@dimen/icon_size_24"
                    android:layout_height="@dimen/icon_size_24"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="@dimen/space_24"
                    android:layout_marginTop="@dimen/space_16"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/content_back"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@color/base_white" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginStart="@dimen/space_24"
                    android:layout_marginTop="76dp"
                    android:layout_marginEnd="@dimen/space_24"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="@dimen/avatar_size_80"
                        android:layout_height="@dimen/avatar_size_80"
                        android:background="@drawable/bg_avatar_circle">

                        <ImageView
                            android:layout_width="@dimen/icon_size_24"
                            android:layout_height="@dimen/icon_size_24"
                            android:layout_gravity="center"
                            android:contentDescription="@string/content_doctor_avatar"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:tint="@color/neutral_600" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/text_detail_name"
                        style="@style/Text.SMD.DisplaySemibold18"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="@string/doctor_default_name"
                        android:textColor="@color/base_white" />

                    <TextView
                        android:id="@+id/text_detail_specialty"
                        style="@style/Text.SMD.Regular14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/specialty_default"
                        android:textColor="@color/base_white" />
                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_24"
                android:layout_marginTop="@dimen/space_16"
                android:layout_marginEnd="@dimen/space_24"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_item"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_12">

                    <TextView
                        android:id="@+id/text_stat_experience_value"
                        style="@style/Text.SMD.DisplaySemibold18"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_unavailable"
                        android:textColor="@color/primary_500" />

                    <TextView
                        style="@style/Text.SMD.Regular12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="yrs"
                        android:textColor="@color/primary_500" />

                    <TextView
                        style="@style/Text.SMD.Regular12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/experience"
                        android:textColor="@color/neutral_400" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_item"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_12">

                    <TextView
                        android:id="@+id/text_stat_patients_value"
                        style="@style/Text.SMD.DisplaySemibold18"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_unavailable"
                        android:textColor="@color/primary_500" />

                    <TextView
                        style="@style/Text.SMD.Regular12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/patients"
                        android:textColor="@color/neutral_400" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_item"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_12">

                    <TextView
                        android:id="@+id/text_stat_rating_value"
                        style="@style/Text.SMD.DisplaySemibold18"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_unavailable"
                        android:textColor="@color/primary_500" />

                    <TextView
                        style="@style/Text.SMD.Regular12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rating"
                        android:textColor="@color/neutral_400" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_24"
                android:layout_marginTop="@dimen/space_16"
                android:layout_marginEnd="@dimen/space_24"
                android:orientation="vertical">

                <TextView
                    style="@style/Text.SMD.TitleMedium16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_doctor" />

                <TextView
                    android:id="@+id/text_about_doctor"
                    style="@style/Text.SMD.Regular14"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/about_doctor_loading"
                    android:textColor="@color/neutral_400" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_24"
                android:layout_marginTop="@dimen/space_16"
                android:layout_marginEnd="@dimen/space_24"
                android:orientation="vertical">

                <TextView
                    style="@style/Text.SMD.TitleMedium16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/date_title" />

                <TextView
                    android:id="@+id/text_schedule_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="No schedule is available yet"
                    android:textColor="@color/neutral_500"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_detail_dates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="7"
                    tools:listitem="@layout/item_date_option" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_24"
                android:layout_marginTop="@dimen/space_16"
                android:layout_marginEnd="@dimen/space_24"
                android:orientation="vertical">

                <TextView
                    style="@style/Text.SMD.TitleMedium16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_title" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_detail_times"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="8"
                    tools:listitem="@layout/item_time_option" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_16" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/button_confirm_schedule"
        style="@style/Widget.SMD.ButtonPrimary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginEnd="@dimen/space_24"
        android:layout_marginBottom="48dp"
        android:text="@string/confirm_schedule"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
