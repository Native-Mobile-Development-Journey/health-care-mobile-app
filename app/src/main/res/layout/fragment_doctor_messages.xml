<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".fragments.DoctorMessagesFragment">

    <TextView
        android:id="@+id/text_doctor_messages_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginTop="@dimen/space_24"
        android:text="Messages"
        style="@style/Text.SMD.DisplaySemibold18"
        android:textColor="@color/base_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_doctor_conversations"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginTop="@dimen/space_16"
        android:layout_marginEnd="@dimen/space_24"
        android:nestedScrollingEnabled="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_doctor_messages_title"
        tools:itemCount="4"
        tools:listitem="@layout/item_conversation" />

    <TextView
        android:id="@+id/text_doctor_messages_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No patient conversations available."
        android:textColor="@color/neutral_500"
        android:textAppearance="@style/Text.SMD.Regular14"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/recycler_doctor_conversations"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/recycler_doctor_conversations" />

</androidx.constraintlayout.widget.ConstraintLayout>
