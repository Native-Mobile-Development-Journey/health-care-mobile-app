<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".fragments.HomeFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_24">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/home_hero_height"
                    android:background="@color/primary_500" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginStart="@dimen/space_24"
                    android:layout_marginTop="@dimen/space_24"
                    android:layout_marginEnd="@dimen/space_24"
                    android:background="@drawable/bg_service_tile_selected"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_8">

                    <FrameLayout
                        android:layout_width="@dimen/avatar_size_40"
                        android:layout_height="@dimen/avatar_size_40"
                        android:background="@drawable/bg_avatar_circle">

                        <ImageView
                            android:layout_width="@dimen/icon_size_24"
                            android:layout_height="@dimen/icon_size_24"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:tint="@color/neutral_600" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Text.SMD.Regular12"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/welcome_back"
                            android:textColor="@color/neutral_300" />

                        <TextView
                            android:id="@+id/text_user_name"
                            style="@style/Text.SMD.DisplaySemibold18"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/user_name"
                            android:textColor="@color/base_white" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_24"
                        android:layout_height="@dimen/icon_size_24"
                        android:contentDescription="@string/content_notification"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="@color/base_white" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_24"
                    android:layout_marginTop="120dp"
                    android:layout_marginEnd="@dimen/space_24"
                    app:cardBackgroundColor="@color/base_white"
                    app:cardCornerRadius="@dimen/radius_12"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/neutral_200"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <TextView
                            style="@style/Text.SMD.LabelMedium14"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/services_title" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recycler_home_services"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:nestedScrollingEnabled="false"
                            tools:itemCount="8"
                            tools:listitem="@layout/item_service" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/space_24"
                android:paddingEnd="@dimen/space_24">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_home_search"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:hint="@string/find_doctor"
                    app:boxBackgroundColor="@color/base_white"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="@color/neutral_300"
                    app:boxStrokeWidth="1dp"
                    app:startIconDrawable="@android:drawable/ic_menu_search">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_home_search"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    style="@style/Text.SMD.LabelMedium14"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/schedule_today" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_schedule_today"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    app:cardBackgroundColor="@color/base_white"
                    app:cardCornerRadius="@dimen/radius_12"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/neutral_200"
                    app:strokeWidth="1dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_today_appointments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:padding="@dimen/space_12"
                        tools:itemCount="1"
                        tools:listitem="@layout/item_appointment" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Text.SMD.LabelMedium14"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/doctors_recommendation" />

                    <TextView
                        android:id="@+id/button_see_more_doctors"
                        style="@style/Text.SMD.Regular12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_more"
                        android:textColor="@color/primary_500" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_home_doctors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="5"
                    tools:listitem="@layout/item_doctor_recommendation" />

                <TextView
                    android:id="@+id/text_home_doctor_empty"
                    style="@style/Text.SMD.Regular12"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="No doctors available yet."
                    android:textColor="@color/neutral_500"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
