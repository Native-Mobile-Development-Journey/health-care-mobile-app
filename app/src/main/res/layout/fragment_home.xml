<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".fragments.HomeFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_24">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/home_hero_height"
                    android:background="@color/primary_500" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginStart="@dimen/space_24"
                    android:layout_marginTop="@dimen/space_24"
                    android:layout_marginEnd="@dimen/space_24"
                    android:background="@drawable/bg_service_tile_selected"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_8">

                    <FrameLayout
                        android:layout_width="@dimen/avatar_size_40"
                        android:layout_height="@dimen/avatar_size_40"
                        android:background="@drawable/bg_avatar_circle">

                        <ImageView
                            android:layout_width="@dimen/icon_size_24"
                            android:layout_height="@dimen/icon_size_24"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:tint="@color/neutral_600" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Text.SMD.Regular12"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/welcome_back"
                            android:textColor="@color/neutral_300" />

                        <TextView
                            style="@style/Text.SMD.DisplaySemibold18"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/user_name"
                            android:textColor="@color/base_white" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_24"
                        android:layout_height="@dimen/icon_size_24"
                        android:contentDescription="@string/content_notification"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="@color/base_white" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_24"
                    android:layout_marginTop="120dp"
                    android:layout_marginEnd="@dimen/space_24"
                    app:cardBackgroundColor="@color/base_white"
                    app:cardCornerRadius="@dimen/radius_12"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/neutral_200"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_dialog_alert"
                                        app:tint="@color/neutral_400" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_emergency" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_compass"
                                        app:tint="@color/neutral_400" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_hospital" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_edit"
                                        app:tint="@color/neutral_400" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_blood" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_agenda"
                                        app:tint="@color/neutral_400" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_prescription" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile_selected">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_info_details"
                                        app:tint="@color/base_white" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_doctor"
                                    android:textColor="@color/primary_500" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_recent_history"
                                        app:tint="@color/neutral_400" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_checkup" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_mylocation"
                                        app:tint="@color/neutral_400" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_location" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="@dimen/avatar_size_56"
                                    android:layout_height="@dimen/avatar_size_56"
                                    android:background="@drawable/bg_service_tile">

                                    <ImageView
                                        android:layout_width="@dimen/icon_size_24"
                                        android:layout_height="@dimen/icon_size_24"
                                        android:layout_gravity="center"
                                        android:src="@android:drawable/ic_menu_search"
                                        app:tint="@color/neutral_400" />
                                </FrameLayout>

                                <TextView
                                    style="@style/Text.SMD.Medium12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_8"
                                    android:text="@string/service_radiology" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/space_24"
                android:paddingEnd="@dimen/space_24">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:background="@drawable/bg_search_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_16"
                    android:paddingTop="@dimen/space_12"
                    android:paddingEnd="@dimen/space_16"
                    android:paddingBottom="@dimen/space_12">

                    <TextView
                        style="@style/Text.SMD.TitleMedium16"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/find_doctor"
                        android:textColor="@color/neutral_300" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_24"
                        android:layout_height="@dimen/icon_size_24"
                        android:contentDescription="@string/content_search"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/neutral_400" />
                </LinearLayout>

                <TextView
                    style="@style/Text.SMD.LabelMedium14"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/schedule_today" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_schedule_today"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    app:cardBackgroundColor="@color/base_white"
                    app:cardCornerRadius="@dimen/radius_12"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/neutral_200"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/space_12">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="66dp"
                            android:background="@drawable/bg_doctor_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_small_location_tag"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="@dimen/space_4"
                                android:paddingTop="@dimen/space_2"
                                android:paddingEnd="@dimen/space_4"
                                android:paddingBottom="@dimen/space_2">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_12"
                                    android:layout_height="@dimen/icon_size_12"
                                    android:src="@android:drawable/ic_menu_mylocation"
                                    app:tint="@color/blue_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_4"
                                    android:text="@string/hospital_cengkareng"
                                    android:textColor="@color/blue_500" />
                            </LinearLayout>

                            <TextView
                                style="@style/Text.SMD.TitleMedium16"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_2"
                                android:text="@string/doctor_zubaidah" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_radiology" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.SMD.Regular12"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/date_july_7" />

                            <TextView
                                style="@style/Text.SMD.Regular12"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:text="@string/time_9_am" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Text.SMD.LabelMedium14"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/doctors_recommendation" />

                    <TextView
                        style="@style/Text.SMD.Regular12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_more"
                        android:textColor="@color/primary_500" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/card_doctor_1"
                            android:layout_width="99dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_8"
                            android:orientation="vertical">

                            <View
                                android:layout_width="99dp"
                                android:layout_height="73dp"
                                android:background="@drawable/bg_doctor_placeholder" />

                            <TextView
                                style="@style/Text.SMD.LabelMedium14"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:text="@string/doctor_jenny"
                                android:textColor="@color/base_black" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_ophthalmologist" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/card_doctor_2"
                            android:layout_width="99dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_8"
                            android:orientation="vertical">

                            <View
                                android:layout_width="99dp"
                                android:layout_height="73dp"
                                android:background="@drawable/bg_doctor_placeholder" />

                            <TextView
                                style="@style/Text.SMD.LabelMedium14"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:text="@string/doctor_jhon"
                                android:textColor="@color/base_black" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_general" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/card_doctor_3"
                            android:layout_width="99dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_8"
                            android:orientation="vertical">

                            <View
                                android:layout_width="99dp"
                                android:layout_height="73dp"
                                android:background="@drawable/bg_doctor_placeholder" />

                            <TextView
                                style="@style/Text.SMD.LabelMedium14"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:text="@string/doctor_betty"
                                android:textColor="@color/base_black" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/service_radiology" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/card_doctor_4"
                            android:layout_width="99dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <View
                                android:layout_width="99dp"
                                android:layout_height="73dp"
                                android:background="@drawable/bg_doctor_placeholder" />

                            <TextView
                                style="@style/Text.SMD.LabelMedium14"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:text="@string/doctor_jenny"
                                android:textColor="@color/base_black" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_ophthalmologist" />
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
