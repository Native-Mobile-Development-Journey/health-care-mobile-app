<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".fragments.ChatFragment">

    <LinearLayout
        android:id="@+id/layout_chat_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginTop="@dimen/space_24"
        android:layout_marginEnd="@dimen/space_24"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/image_chat_avatar"
            android:layout_width="@dimen/avatar_size_40"
            android:layout_height="@dimen/avatar_size_40"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="@string/content_chat_avatar"
            android:padding="@dimen/space_8"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/neutral_600" />

        <TextView
            android:id="@+id/text_chat_title"
            style="@style/Text.SMD.DisplaySemibold18"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:text="Chat"
            android:textColor="@color/base_black" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_chat_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:paddingStart="@dimen/space_24"
        android:paddingTop="@dimen/space_12"
        android:paddingEnd="@dimen/space_24"
        android:paddingBottom="@dimen/space_8"
        app:layout_constraintBottom_toTopOf="@id/layout_chat_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_chat_header"
        tools:itemCount="4"
        tools:listitem="@layout/item_message" />

    <TextView
        android:id="@+id/text_chat_empty"
        style="@style/Text.SMD.Regular14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No messages yet"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layout_chat_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_chat_header" />

    <LinearLayout
        android:id="@+id/layout_chat_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_16"
        android:layout_marginStart="@dimen/space_24"
        android:layout_marginEnd="@dimen/space_24"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_chat_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/type_message"
            android:inputType="text"
            android:maxLines="4"
            android:background="@color/base_white"
            android:padding="12dp" />

        <ImageButton
            android:id="@+id/button_chat_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/send_message"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/primary_500" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
