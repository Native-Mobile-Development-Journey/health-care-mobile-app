<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    tools:context=".fragments.ScheduleFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_24"
            android:paddingTop="@dimen/space_20"
            android:paddingEnd="@dimen/space_24"
            android:paddingBottom="@dimen/space_24">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_field"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_16"
                android:paddingTop="@dimen/space_12"
                android:paddingEnd="@dimen/space_16"
                android:paddingBottom="@dimen/space_12">

                <TextView
                    style="@style/Text.SMD.TitleMedium16"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/find_schedule"
                    android:textColor="@color/neutral_300" />

                <ImageView
                    android:layout_width="@dimen/icon_size_24"
                    android:layout_height="@dimen/icon_size_24"
                    android:contentDescription="@string/content_search"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/neutral_400" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_active"
                    android:paddingStart="@dimen/space_16"
                    android:paddingTop="@dimen/space_8"
                    android:paddingEnd="@dimen/space_16"
                    android:paddingBottom="@dimen/space_8"
                    android:text="All"
                    android:textColor="@color/base_white"
                    android:textSize="@dimen/text_12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="@dimen/space_16"
                    android:paddingTop="@dimen/space_8"
                    android:paddingEnd="@dimen/space_16"
                    android:paddingBottom="@dimen/space_8"
                    android:text="Upcoming"
                    android:textColor="@color/neutral_400"
                    android:textSize="@dimen/text_12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="@dimen/space_16"
                    android:paddingTop="@dimen/space_8"
                    android:paddingEnd="@dimen/space_16"
                    android:paddingBottom="@dimen/space_8"
                    android:text="Completed"
                    android:textColor="@color/neutral_400"
                    android:textSize="@dimen/text_12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="@dimen/space_16"
                    android:paddingTop="@dimen/space_8"
                    android:paddingEnd="@dimen/space_16"
                    android:paddingBottom="@dimen/space_8"
                    android:text="Cancel"
                    android:textColor="@color/neutral_400"
                    android:textSize="@dimen/text_12" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_appointment_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                app:cardBackgroundColor="@color/base_white"
                app:cardCornerRadius="@dimen/radius_16"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="61dp"
                            android:background="@drawable/bg_doctor_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.SMD.TitleMedium16"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/doctor_zubaidah" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_radiology" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_12"
                                    android:layout_height="@dimen/icon_size_12"
                                    android:src="@android:drawable/ic_menu_mylocation"
                                    app:tint="@color/blue_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_4"
                                    android:text="@string/hospital_cengkareng"
                                    android:textColor="@color/blue_500" />
                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_cancel"
                            android:paddingStart="@dimen/space_8"
                            android:paddingTop="@dimen/space_4"
                            android:paddingEnd="@dimen/space_8"
                            android:paddingBottom="@dimen/space_4"
                            android:text="@string/status_cancel"
                            android:textColor="@color/red_500"
                            android:textSize="@dimen/text_8" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_12"
                        android:background="@color/neutral_200" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_14"
                                    android:layout_height="@dimen/icon_size_14"
                                    android:src="@android:drawable/ic_menu_recent_history"
                                    app:tint="@color/neutral_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_8"
                                    android:text="@string/time_9_am" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_6"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_14"
                                    android:layout_height="@dimen/icon_size_14"
                                    android:src="@android:drawable/ic_menu_my_calendar"
                                    app:tint="@color/neutral_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_8"
                                    android:text="@string/date_july_7" />
                            </LinearLayout>

                        </LinearLayout>

                        <Button
                            android:id="@+id/button_reschedule_1"
                            style="@style/Widget.SMD.ButtonPrimary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/action_reschedule"
                            android:textAllCaps="false" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_appointment_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                app:cardBackgroundColor="@color/base_white"
                app:cardCornerRadius="@dimen/radius_16"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="61dp"
                            android:background="@drawable/bg_doctor_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.SMD.TitleMedium16"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/doctor_claire" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_dentistry" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_12"
                                    android:layout_height="@dimen/icon_size_12"
                                    android:src="@android:drawable/ic_menu_mylocation"
                                    app:tint="@color/blue_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_4"
                                    android:text="@string/hospital_cengkareng"
                                    android:textColor="@color/blue_500" />
                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_complete"
                            android:paddingStart="@dimen/space_8"
                            android:paddingTop="@dimen/space_4"
                            android:paddingEnd="@dimen/space_8"
                            android:paddingBottom="@dimen/space_4"
                            android:text="@string/status_complete"
                            android:textColor="@color/green_500"
                            android:textSize="@dimen/text_8" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_12"
                        android:background="@color/neutral_200" />

                    <Button
                        android:id="@+id/button_new_appointment"
                        style="@style/Widget.SMD.ButtonPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:text="@string/action_new_appointment"
                        android:textAllCaps="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_appointment_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                app:cardBackgroundColor="@color/base_white"
                app:cardCornerRadius="@dimen/radius_16"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="61dp"
                            android:background="@drawable/bg_doctor_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.SMD.TitleMedium16"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/doctor_harold" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_ent" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_12"
                                    android:layout_height="@dimen/icon_size_12"
                                    android:src="@android:drawable/ic_menu_mylocation"
                                    app:tint="@color/blue_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_4"
                                    android:text="@string/hospital_cengkareng"
                                    android:textColor="@color/blue_500" />
                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_upcoming_blue"
                            android:paddingStart="@dimen/space_8"
                            android:paddingTop="@dimen/space_4"
                            android:paddingEnd="@dimen/space_8"
                            android:paddingBottom="@dimen/space_4"
                            android:text="@string/status_upcoming"
                            android:textColor="@color/blue_500"
                            android:textSize="@dimen/text_8" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_12"
                        android:background="@color/neutral_200" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_14"
                                    android:layout_height="@dimen/icon_size_14"
                                    android:src="@android:drawable/ic_menu_recent_history"
                                    app:tint="@color/neutral_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_8"
                                    android:text="@string/time_9_am" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_6"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_14"
                                    android:layout_height="@dimen/icon_size_14"
                                    android:src="@android:drawable/ic_menu_my_calendar"
                                    app:tint="@color/neutral_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_8"
                                    android:text="@string/date_july_7" />
                            </LinearLayout>

                        </LinearLayout>

                        <Button
                            android:id="@+id/button_reschedule_3"
                            style="@style/Widget.SMD.ButtonPrimary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/action_reschedule"
                            android:textAllCaps="false" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_appointment_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                app:cardBackgroundColor="@color/base_white"
                app:cardCornerRadius="@dimen/radius_16"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="61dp"
                            android:background="@drawable/bg_doctor_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.SMD.TitleMedium16"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/doctor_serenity" />

                            <TextView
                                style="@style/Text.SMD.Regular10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/specialty_radiology" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_12"
                                    android:layout_height="@dimen/icon_size_12"
                                    android:src="@android:drawable/ic_menu_mylocation"
                                    app:tint="@color/blue_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_4"
                                    android:text="@string/hospital_cengkareng"
                                    android:textColor="@color/blue_500" />
                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_upcoming_yellow"
                            android:paddingStart="@dimen/space_8"
                            android:paddingTop="@dimen/space_4"
                            android:paddingEnd="@dimen/space_8"
                            android:paddingBottom="@dimen/space_4"
                            android:text="@string/status_upcoming"
                            android:textColor="@color/yellow_500"
                            android:textSize="@dimen/text_8" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_12"
                        android:background="@color/neutral_200" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_14"
                                    android:layout_height="@dimen/icon_size_14"
                                    android:src="@android:drawable/ic_menu_recent_history"
                                    app:tint="@color/neutral_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_8"
                                    android:text="@string/time_9_am" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_6"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/icon_size_14"
                                    android:layout_height="@dimen/icon_size_14"
                                    android:src="@android:drawable/ic_menu_my_calendar"
                                    app:tint="@color/neutral_500" />

                                <TextView
                                    style="@style/Text.SMD.Regular12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_8"
                                    android:text="@string/date_july_7" />
                            </LinearLayout>

                        </LinearLayout>

                        <Button
                            android:id="@+id/button_reschedule_4"
                            style="@style/Widget.SMD.ButtonPrimary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/action_reschedule"
                            android:textAllCaps="false" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
