<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_setting_option_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_stat_item"
    android:orientation="vertical"
    android:padding="@dimen/space_12">

    <LinearLayout
        android:id="@+id/layout_setting_option_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_service_tile">

            <ImageView
                android:id="@+id/image_setting_icon"
                android:layout_width="@dimen/icon_size_24"
                android:layout_height="@dimen/icon_size_24"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="@color/neutral_500" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_setting_title"
                style="@style/Text.SMD.LabelMedium14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setting" />

            <TextView
                android:id="@+id/text_setting_subtitle"
                style="@style/Text.SMD.Regular12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="Description"
                android:textColor="@color/neutral_500" />
        </LinearLayout>

        <ImageView
            android:layout_width="@dimen/icon_size_24"
            android:layout_height="@dimen/icon_size_24"
            android:src="@android:drawable/ic_media_next"
            android:tint="@color/neutral_400" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_setting_inline_security_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:background="@drawable/bg_security_panel"
        android:orientation="vertical"
        android:padding="@dimen/space_12"
        android:visibility="gone">

        <EditText
            android:id="@+id/input_setting_inline_new_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_stat_item"
            android:hint="@string/settings_change_password_hint"
            android:inputType="textPassword"
            android:maxLines="1"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_12" />

        <Button
            android:id="@+id/button_setting_inline_change_password"
            style="@style/Widget.SMD.ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:text="@string/settings_change_password_action" />

    </LinearLayout>

</LinearLayout>
